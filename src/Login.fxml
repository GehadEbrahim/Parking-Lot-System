<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="680.0" prefWidth="530.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginController">
   <children>
      <ImageView fitHeight="683.0" fitWidth="548.0" layoutX="-4.0" layoutY="-2.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/car.jpg" />
         </image>
         <effect>
            <GaussianBlur radius="4.0" />
         </effect>
      </ImageView>
            <TextField fx:id="username" layoutX="186.0" layoutY="305.0" prefHeight="40.0" prefWidth="165.0" promptText="Enter your name">
               <font>
                  <Font name="Arial" size="14.0" />
               </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
            </TextField>
      <PasswordField id="passTextFild" fx:id="password" layoutX="189.0" layoutY="377.0" prefHeight="34.0" prefWidth="159.0" promptText="Enter your password" stylesheets="@style.css">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </PasswordField>
      <Button id="loginBtn" layoutX="185.0" layoutY="454.0" mnemonicParsing="false" onAction="#login" prefHeight="28.0" prefWidth="166.0" style="-fx-background-color: #ffffff; -fx-border-color: white;" text="Login">
         <font>
            <Font name="Arial" size="14.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <ImageView id="loginIcon" fitHeight="15.0" fitWidth="15.0" layoutX="327.0" layoutY="318.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/userMain.png" />
         </image>
         <effect>
            <ColorAdjust brightness="1.0" />
         </effect>
      </ImageView>
      <ImageView fitHeight="17.0" fitWidth="15.0" layoutX="327.0" layoutY="387.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/padlock.png" />
         </image>
         <effect>
            <ColorAdjust brightness="1.0" />
         </effect>
      </ImageView>
      <ImageView fitHeight="132.0" fitWidth="130.0" layoutX="204.0" layoutY="113.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/user.png" />
         </image>
         <effect>
            <ColorAdjust brightness="1.0" />
         </effect>
      </ImageView>
      <ImageView fx:id="backBtn" fitHeight="26.0" fitWidth="25.0" layoutX="21.0" layoutY="14.0" onMouseClicked="#back" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/backward-button-white-icon.png" />
         </image>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </ImageView>
   </children>
</AnchorPane>
